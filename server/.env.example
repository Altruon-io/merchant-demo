# ──────────────────────────────────────────────────────────────────────────────
# Altruon Merchant Demo — server configuration
#
# Copy this file to `.env` (same folder) and fill in your own values:
#
#     cp .env.example .env
#
# Everything you need can be found in your Altruon dashboard:
#   - API keys:            Dashboard → Developers → API Keys
#   - Billing connection:  Dashboard → Integrations → Billing Providers
#   - Plans / addons:      Your billing provider (Stripe, Chargebee, Recurly, ...)
#
# Docs: https://docs.altruon.io/docs/developers/altruon-js/quick-start
# ──────────────────────────────────────────────────────────────────────────────

# ── Altruon credentials ───────────────────────────────────────────────────────

# SECRET key (server-side only — never expose this to the browser).
# Used for: creating checkout sessions, fetching transaction details.
# Format: sk_sandbox_... (sandbox) or sk_altruon_... (production)
ALTRUON_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxxxxxxxxxxxx

# PUBLISHABLE key (safe to expose — the frontend SDK uses it).
# Format: pk_sandbox_... (sandbox) or pk_altruon_... (production)
ALTRUON_PUBLISHABLE_KEY=pk_sandbox_xxxxxxxxxxxxxxxxxxxxxxxx

# Your Altruon domain. Accepts any of:
#   - your checkout domain:  mycompany.sandbox.altruon.io
#   - your API domain:       mycompany.api.sandbox.altruon.io
#   - just your tenant name: mycompany   (environment inferred from key prefix)
ALTRUON_DOMAIN=mycompany.sandbox.altruon.io

# ── Checkout configuration (what the demo sells) ──────────────────────────────

# Billing connection UUID — identifies WHICH billing provider connection
# (Stripe, Chargebee, Recurly, ...) Altruon should create the subscription on.
# Find it under: Dashboard → Integrations → Billing Providers.
BILLING_CONNECTION_ID=00000000-0000-0000-0000-000000000000

# The plan "item price" id at your billing provider (e.g. a Stripe price id).
# Exactly one plan is required per checkout session.
PLAN_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional, comma-separated list of recurring addon item price ids.
# Example: ADDON_IDS=price_addon_seats,price_addon_storage
ADDON_IDS=

# ISO 4217 currency for the checkout session (must exist on the plan price).
CURRENCY=EUR

# ── Storefront branding (optional) ────────────────────────────────────────────
# The demo ships with a fictional "MySaas" brand. Override these to instantly
# preview the checkout with YOUR brand (also editable live in the demo UI).

MERCHANT_DISPLAY_NAME=
MERCHANT_LOGO_URL=

# ── Server ────────────────────────────────────────────────────────────────────

# Port for this demo backend (the Vite dev server proxies /api here).
PORT=4242
